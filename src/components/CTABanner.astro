---
// src/components/CTABanner.astro

interface Props {
  headline: string;
  subheadline: string;
  buttonText: string;
  buttonLink: string;
}

const { 
  headline, 
  subheadline, 
  buttonText, 
  buttonLink 
} = Astro.props;
---

<section class="bg-brand-card/80 border border-white/10 backdrop-blur-lg py-16 md:py-24 px-6 rounded-2xl text-center relative overflow-hidden shadow-2xl shadow-black/20">
  <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-accent-orange via-transparent to-transparent"></div>
  <h2 class="font-heading text-h2 md:text-h1 gradient-text mb-6 relative z-10">{headline}</h2>
  <p class="text-brand-text text-lg max-w-2xl mx-auto mb-10 relative z-10">{subheadline}</p>
  <a 
    href={buttonLink} 
    class="inline-block bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold px-8 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300 hover:-translate-y-1 relative z-10"
    data-ga-cta={buttonText}
    data-ga-location="CTA Banner"
  >{buttonText}</a>
</section>