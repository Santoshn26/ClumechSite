---
// src/components/StepProcess.astro
export interface Props {
  stepNumber: string;
  title: string;
  description: string;
  onLightBg?: boolean;
  isLast?: boolean; // Prop for potential connector line logic
}

const { stepNumber, title, description, onLightBg = false, isLast = false } = Astro.props;

// Conditionally set text colors based on the background
const titleColor = onLightBg ? 'text-slate-900' : 'text-white';
const textColor = onLightBg ? 'text-slate-700' : 'text-slate-300';
const borderColor = onLightBg ? 'border-slate-300' : 'border-brand-border';
const numberColor = onLightBg ? 'text-slate-500' : 'text-slate-400';
const connectorColor = onLightBg ? 'border-slate-300' : 'border-brand-border';
---

<div class="relative flex-1 text-center md:text-left">
  <div class:list={["relative z-10", onLightBg ? 'bg-light-bg' : 'bg-brand-surface', 'md:bg-transparent']}>
    <div class:list={["flex items-center justify-center w-12 h-12 rounded-full border-2 font-mono font-bold text-lg mb-4 mx-auto md:mx-0", borderColor, numberColor]}>
      {stepNumber}
    </div>
    <h3 class:list={["font-heading font-semibold text-xl mb-2", titleColor]}>{title}</h3>
    <p class:list={["max-w-xs mx-auto md:mx-0", textColor]}>{description}</p>
  </div>

  <!-- Connector line for desktop -->
  { !isLast && 
    <div class:list={["hidden md:block absolute top-6 w-full border-t-2 border-dashed", connectorColor]} style="left: 3.5rem; width: calc(100% - 3.5rem);"></div>
  }
  <!-- Connector line for mobile -->
  { !isLast &&
    <div class:list={["md:hidden absolute top-12 left-1/2 h-full border-l-2 border-dashed -translate-x-1/2 z-[-1]", connectorColor]} style="height: calc(100% + 2rem);"></div>
  }
</div>