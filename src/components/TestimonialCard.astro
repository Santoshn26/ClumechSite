---
// src/components/TestimonialCard.astro

export interface Props {
  name: string;
  role: string;
  company?: string;
  content: string;
  avatarUrl?: string;
  onLightBg?: boolean;
}

const { 
  name, 
  role, 
  company, 
  content, 
  avatarUrl,
  onLightBg = false
} = Astro.props;

// Conditionally set colors based on the background
const containerClasses = onLightBg 
  ? 'bg-white p-8 rounded-2xl border border-slate-200 shadow-sm flex flex-col h-full'
  : 'bg-brand-card/80 p-8 rounded-2xl border border-white/10 backdrop-blur-lg shadow-lg shadow-black/20 flex flex-col h-full';

const quoteIconColor = onLightBg ? 'text-slate-400' : 'text-accent-orange';
const contentColor = onLightBg ? 'text-slate-600' : 'text-slate-300';
const nameColor = onLightBg ? 'text-slate-800' : 'text-white';
const roleColor = onLightBg ? 'text-slate-500' : 'text-slate-400';
const avatarBg = onLightBg ? 'bg-slate-100 border-slate-200' : 'bg-brand-surface border-brand-border';
const avatarTextColor = onLightBg ? 'text-slate-500' : 'text-slate-400';
---

<div class:list={[containerClasses]}>
  <div class:list={[quoteIconColor, "mb-4"]}>
    <svg class="w-8 h-8 opacity-50" fill="currentColor" viewBox="0 0 32 32" aria-hidden="true">
      <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z" />
    </svg>
  </div>
  <p class:list={["font-medium italic text-lg mb-8 flex-grow leading-relaxed", contentColor]}>"{content}"</p>
  <div class="flex items-center gap-4 mt-auto">
    {avatarUrl 
      ? <img src={avatarUrl} alt={name} class:list={["w-12 h-12 rounded-full object-cover border", onLightBg ? 'border-slate-200' : 'border-brand-border']} loading="lazy"/> 
      : <div class:list={["w-12 h-12 rounded-full flex items-center justify-center font-bold", avatarBg, avatarTextColor]}>{name.charAt(0)}</div>}
    <div>
      <p class:list={["font-bold text-sm", nameColor]}>{name}</p>
      <p class:list={["text-xs", roleColor]}>{role}{company ? `, ${company}` : ''}</p>
    </div>
  </div>
</div>