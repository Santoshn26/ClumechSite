---
// src/components/Navbar.astro

const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/') return currentPath === '/';
  return currentPath === path || currentPath.startsWith(path + '/');
}

export interface NavLink {
  label: string;
  href: string;
}

export interface Props {
  /** The text for the main call-to-action button. Defaults to "Request Demo". */
  ctaText?: string;

  /** The URL for the main call-to-action button. Defaults to "/demo". */
  ctaLink?: string;
}

const links: NavLink[] = [
  { label: "Products",   href: "/products" },
  { label: "Industries", href: "/industries" },
  { label: "Work",       href: "/work" },
  { label: "About",      href: "/about" },
  { label: "Contact",    href: "/contact" }
];

const {
  ctaText = "Request a Quote",
  ctaLink = "/contact"
} = Astro.props;
---

<header id="main-header" class="sticky top-0 z-50 w-full bg-brand-navy/80 backdrop-blur-lg border-b border-brand-border/50">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="flex justify-between items-center h-16">
      
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center gap-4">
        <a href="/" class="logo-link flex items-center">
          <div class="w-24 h-12 flex items-center justify-center bg-white rounded-lg shadow-sm">
            <img 
              src="/images/clumech-logo.png" 
              alt="Clumech LLP Logo" 
              class="h-10 object-contain"
              loading="eager"
            >
          </div>
        </a>
        <div class="hidden sm:flex items-center border-l border-brand-border/50 pl-4">
          <p class="text-slate-400 text-xs font-medium tracking-wider leading-tight">
            Designing Space.<br class="hidden lg:block">
            Delivering Solutions.
          </p>
        </div>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8 items-center">
        {links.map(link => (
          <a 
            href={link.href}
            class:list={[
              'nav-link', // For JS targeting
              'relative text-sm font-medium border-b-2 pb-0.5', // Common styles
              isActive(link.href)
                ? 'active-link'
                : 'inactive-link'
            ]}
          >
            {link.label}
          </a>
        ))}
        <a 
          href={ctaLink} 
          class="bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300"
          data-ga-cta={ctaText}
          data-ga-location="Navbar"
        >
          {ctaText}
        </a>
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" type="button" class="text-brand-bright hover:text-white focus:outline-none p-2" aria-label="Toggle menu" aria-expanded="false">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Panel (outside header for correct stacking context) -->
<div 
  id="mobile-menu"
  class="fixed top-16 left-0 right-0 bottom-0 z-[60] md:hidden transform translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto"
  style="background: rgba(10, 15, 30, 0.97); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);"
  aria-hidden="true"
  role="dialog"
>
  <!-- Top border accent line -->
  <div class="h-[1px] w-full" style="background: linear-gradient(90deg, transparent, rgba(249,115,22,0.5), transparent);"></div>

  <!-- Menu content -->
  <div class="px-6 py-8 flex flex-col gap-1">
    
    <!-- Nav links with stagger animation -->
    {links.map((link, index) => (
      <a 
        href={link.href}
        class:list={[
          'mobile-link flex items-center gap-3 px-4 py-4 rounded-xl text-base font-medium transition-all duration-200',
          isActive(link.href)
            ? 'bg-orange-500/10 text-white border border-orange-500/30'
            : 'text-slate-300 hover:bg-white/5 hover:text-white border border-transparent'
        ]}
        style={`transition-delay: ${index * 60}ms`}
      >
        {/* Active indicator dot */}
        {isActive(link.href) ? (
          <span class="w-1.5 h-1.5 rounded-full bg-orange-500 flex-shrink-0" style="box-shadow: 0 0 6px rgba(249,115,22,0.8);"></span>
        ) : (
          <span class="w-1.5 h-1.5 rounded-full bg-slate-600 flex-shrink-0"></span>
        )}
        {link.label}
      </a>
    ))}

    <!-- Divider -->
    <div class="my-4 h-[1px] bg-white/10"></div>

    <!-- CTA button -->
    <a 
      href={ctaLink}
      class="mobile-link flex items-center justify-center gap-2 w-full py-4 px-6 rounded-xl font-semibold text-base text-white transition-all duration-200"
      style={`background: linear-gradient(135deg, #F97316, #EA6C0A); box-shadow: 0 0 30px rgba(249,115,22,0.3); transition-delay: ${links.length * 60}ms;`}
      data-ga-cta={ctaText}
      data-ga-location="Mobile Menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h8m0 0l-4-4m4 4l-4 4"/></svg>
      {ctaText}
    </a>

    <!-- Bottom info strip -->
    <div class="mt-8 pt-6 border-t border-white/10">
      <p class="text-slate-400 text-xs text-center font-medium tracking-wider mb-2">Designing Space. Delivering Solutions.</p>
      <p class="text-slate-500 text-xs text-center font-mono tracking-wider">BENGALURU · PUNE · EST. 2021</p>
      <p class="text-slate-600 text-xs text-center mt-1">info@clumech.com</p>
    </div>
  </div>
</div>

<style>
  /* --- Accessibility --- */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
      animation-iteration-count: 1 !important; /* Also disable repeated animations */
    }
  }

  /* EFFECT 4 — Navbar scroll effect */
  #main-header {
    transition: background-color 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease, box-shadow 0.3s ease;
  }
  #main-header.scrolled {
    background-color: rgba(10, 15, 30, 0.97); /* bg-brand-navy/97 */
    border-bottom-color: rgba(51, 65, 85, 0.8); /* brand-border/80 */
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
  }

  /* EFFECT 6 — Logo: subtle hover animation */
  .logo-link {
    transition: transform 0.2s ease, text-shadow 0.2s ease;
    display: inline-block;
  }
  .logo-link:hover {
    transform: scale(1.03);
    text-shadow: 0 0 20px rgba(249, 115, 22, 0.3);
  }

  /* --- Desktop Nav Link Effects --- */

  /* EFFECT 1 — Active tab: ambient orange glow */
  .active-link {
    color: #FFFFFF;
    border-color: #F97316; /* accent-orange */
    text-shadow: 0 0 20px rgba(249, 115, 22, 0.4);
  }
  .active-link::after {
    content: '';
    position: absolute;
    left: -4px;
    right: -4px;
    bottom: -4px;
    height: 12px;
    background: radial-gradient(
      ellipse at center,
      rgba(249, 115, 22, 0.35) 0%,
      rgba(249, 115, 22, 0.0) 70%
    );
    animation: ambientGlow 3s ease-in-out infinite;
    pointer-events: none;
    z-index: -1;
  }

  @keyframes ambientGlow {
    0%, 100% { opacity: 0.6; transform: scaleX(0.8); }
    50% { opacity: 1; transform: scaleX(1.1); }
  }

  /* EFFECT 3 — Inactive tabs hover: smooth orange creep */
  .inactive-link {
    color: #94a3b8; /* slate-400 */
    border-color: transparent;
    transition: color 0.2s ease;
  }
  .inactive-link:hover {
    color: #FFFFFF;
  }
  .inactive-link::before {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    right: 50%;
    height: 1px;
    background: rgba(249, 115, 22, 0.5);
    transition: left 0.2s ease, right 0.2s ease;
  }
  .inactive-link:hover::before {
    left: 0;
    right: 0;
  }

  /* EFFECT 2 — Click ripple animation */
  .nav-clicked {
    animation: navClick 0.3s ease-out forwards;
  }
  @keyframes navClick {
    0%   { color: #F97316; text-shadow: 0 0 12px rgba(249,115,22,0.9); }
    100% { color: inherit; text-shadow: none; }
  }

  /* --- Mobile Menu Effects --- */

  /* EFFECT 5 — Mobile menu: slide in from right */
  .mobile-menu-open {
    transform: translateX(0);
  }
  .mobile-link {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .mobile-menu-open .mobile-link {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('main-header');
    if (!header) return;

    // --- Mobile Menu Logic (EFFECT 5) ---
    const btn = header.querySelector('#mobile-menu-btn');
    const menu = document.getElementById('mobile-menu'); // It's now a sibling
    const menuLinks = menu?.querySelectorAll('.mobile-link');

    if (btn && menu && header) {
      const toggleMenu = () => {
        const isOpen = menu.classList.toggle('mobile-menu-open');
        document.body.style.overflow = isOpen ? 'hidden' : '';
        btn.setAttribute('aria-expanded', String(isOpen));
        menu.setAttribute('aria-hidden', String(!isOpen));
      };

      btn.addEventListener('click', toggleMenu);
      // Close menu when a link is clicked
      menuLinks?.forEach(link => link.addEventListener('click', () => {
        // Don't close for on-page hash links
        if (link.getAttribute('href')?.startsWith('#')) return;
        toggleMenu();
      }));
    }

    // --- EFFECT 4: Navbar scroll effect ---
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    }, { passive: true });

    // --- EFFECT 2: Click ripple animation ---
    const allNavLinks = document.querySelectorAll('.nav-link, .mobile-link');
    allNavLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const target = e.currentTarget;
        // Don't apply to the main CTA button which has its own effects
        if (target.dataset.gaCta) return;

        target.classList.add('nav-clicked');
        
        setTimeout(() => {
          target.classList.remove('nav-clicked');
        }, 300);
      });
    });
  });
</script>
