---
// src/components/Navbar.astro

const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/') return currentPath === '/';
  return currentPath === path || currentPath.startsWith(path + '/');
}

export interface NavLink {
  label: string;
  href: string;
}

export interface Props {
  /** The text to display as the logo in the navbar. Defaults to "BrandLogo". */
  logoText?: string;

  /** An array of navigation links to display in the navbar. */
  links?: NavLink[];

  /** The text for the main call-to-action button. Defaults to "Request Demo". */
  ctaText?: string;

  /** The URL for the main call-to-action button. Defaults to "/demo". */
  ctaLink?: string;
}

const {
  logoText = "BrandLogo",
  links = [
    { label: "Platform", href: "/" },
    { label: "Products", href: "/services" },
    { label: "Systems", href: "/systems" },
    { label: "Case Studies", href: "/case-studies" },
    { label: "About", href: "/about" },
    { label: "Contact", href: "/contact" }
  ],
  ctaText = "Request Demo",
  ctaLink = "/demo"
} = Astro.props;
---

<header id="main-header" class="sticky top-0 z-50 w-full bg-brand-navy/80 backdrop-blur-lg border-b border-brand-border/50">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="flex justify-between items-center h-16">
      
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="logo-link font-heading font-bold text-2xl tracking-tight text-brand-bright">{logoText}</a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8 items-center">
        {links.map(link => (
          <a 
            href={link.href}
            class:list={[
              'nav-link', // For JS targeting
              'relative text-sm font-medium border-b-2 pb-0.5', // Common styles
              isActive(link.href)
                ? 'active-link'
                : 'inactive-link'
            ]}
          >
            {link.label}
          </a>
        ))}
        <a 
          href={ctaLink} 
          class="bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300"
          data-ga-cta={ctaText}
          data-ga-location="Navbar"
        >
          {ctaText}
        </a>
      </nav>

      <!-- Mobile menu button -->
      <div class="flex md:hidden items-center">
        <button id="mobile-menu-btn" type="button" class="text-brand-bright hover:text-white focus:outline-none p-2" aria-label="Toggle menu">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Panel -->
  <div id="mobile-menu" class="fixed inset-0 top-16 z-40 bg-brand-navy/95 backdrop-blur-xl transform translate-x-full opacity-0 transition-all duration-300 ease-in-out md:hidden">
    <div class="px-2 pt-2 pb-4 space-y-1 sm:px-3 flex flex-col">
      {links.map(link => (
        <a href={link.href} class="mobile-link block px-3 py-3 rounded-md text-base font-medium text-brand-text hover:bg-brand-card hover:text-brand-bright transition-colors">
          {link.label}
        </a>
      ))}
      <a 
        href={ctaLink} 
        class="mobile-link block w-full text-center mt-4 bg-accent-orange hover:bg-accent-orangeHover text-white px-6 py-3 rounded-xl font-semibold text-base transition-colors shadow-cta-orange"
        data-ga-cta={ctaText}
        data-ga-location="Mobile Menu"
      >
        {ctaText}
      </a>
    </div>
  </div>
</header>

<style>
  /* --- Accessibility --- */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
      animation-iteration-count: 1 !important; /* Also disable repeated animations */
    }
  }

  /* EFFECT 4 — Navbar scroll effect */
  #main-header {
    transition: background-color 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease, box-shadow 0.3s ease;
  }
  #main-header.scrolled {
    background-color: rgba(10, 15, 30, 0.97); /* bg-brand-navy/97 */
    border-bottom-color: rgba(51, 65, 85, 0.8); /* brand-border/80 */
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
  }

  /* EFFECT 6 — Logo: subtle hover animation */
  .logo-link {
    transition: transform 0.2s ease, text-shadow 0.2s ease;
    display: inline-block;
  }
  .logo-link:hover {
    transform: scale(1.03);
    text-shadow: 0 0 20px rgba(249, 115, 22, 0.3);
  }

  /* --- Desktop Nav Link Effects --- */

  /* EFFECT 1 — Active tab: ambient orange glow */
  .active-link {
    color: #FFFFFF;
    border-color: #F97316; /* accent-orange */
    text-shadow: 0 0 20px rgba(249, 115, 22, 0.4);
  }
  .active-link::after {
    content: '';
    position: absolute;
    left: -4px;
    right: -4px;
    bottom: -4px;
    height: 12px;
    background: radial-gradient(
      ellipse at center,
      rgba(249, 115, 22, 0.35) 0%,
      rgba(249, 115, 22, 0.0) 70%
    );
    animation: ambientGlow 3s ease-in-out infinite;
    pointer-events: none;
    z-index: -1;
  }

  @keyframes ambientGlow {
    0%, 100% { opacity: 0.6; transform: scaleX(0.8); }
    50% { opacity: 1; transform: scaleX(1.1); }
  }

  /* EFFECT 3 — Inactive tabs hover: smooth orange creep */
  .inactive-link {
    color: #94a3b8; /* slate-400 */
    border-color: transparent;
    transition: color 0.2s ease;
  }
  .inactive-link:hover {
    color: #FFFFFF;
  }
  .inactive-link::before {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    right: 50%;
    height: 1px;
    background: rgba(249, 115, 22, 0.5);
    transition: left 0.2s ease, right 0.2s ease;
  }
  .inactive-link:hover::before {
    left: 0;
    right: 0;
  }

  /* EFFECT 2 — Click ripple animation */
  .nav-clicked {
    animation: navClick 0.3s ease-out forwards;
  }
  @keyframes navClick {
    0%   { color: #F97316; text-shadow: 0 0 12px rgba(249,115,22,0.9); }
    100% { color: inherit; text-shadow: none; }
  }

  /* --- Mobile Menu Effects --- */

  /* EFFECT 5 — Mobile menu: slide + fade with stagger */
  .mobile-menu-open {
    opacity: 1;
    transform: translateX(0);
  }
  .mobile-link {
    opacity: 0;
    transform: translateX(-12px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .mobile-menu-open .mobile-link {
    opacity: 1;
    transform: translateX(0);
  }
  /* Staggered delays */
  .mobile-menu-open .mobile-link:nth-child(1) { transition-delay: 0.05s; }
  .mobile-menu-open .mobile-link:nth-child(2) { transition-delay: 0.10s; }
  .mobile-menu-open .mobile-link:nth-child(3) { transition-delay: 0.15s; }
  .mobile-menu-open .mobile-link:nth-child(4) { transition-delay: 0.20s; }
  .mobile-menu-open .mobile-link:nth-child(5) { transition-delay: 0.25s; }
  .mobile-menu-open .mobile-link:nth-child(6) { transition-delay: 0.30s; }
  .mobile-menu-open .mobile-link:nth-child(7) { transition-delay: 0.35s; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('main-header');
    if (!header) return;

    // --- Mobile Menu Logic (EFFECT 5) ---
    const btn = header.querySelector('#mobile-menu-btn');
    const menu = header.querySelector('#mobile-menu');
    const menuLinks = menu?.querySelectorAll('.mobile-link');

    if (btn && menu) {
      const toggleMenu = () => {
        const isCurrentlyOpen = menu.classList.contains('mobile-menu-open');
        
        // Toggle the state
        menu.classList.toggle('mobile-menu-open');
        document.body.classList.toggle('overflow-hidden', !isCurrentlyOpen);
      };

      btn.addEventListener('click', toggleMenu);
      // Close menu when a link is clicked
      menuLinks?.forEach(link => link.addEventListener('click', toggleMenu));
    }

    // --- EFFECT 4: Navbar scroll effect ---
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    }, { passive: true });

    // --- EFFECT 2: Click ripple animation ---
    const allNavLinks = document.querySelectorAll('.nav-link, .mobile-link');
    allNavLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const target = e.currentTarget;
        // Don't apply to the main CTA button which has its own effects
        if (target.dataset.gaCta) return;

        target.classList.add('nav-clicked');
        
        setTimeout(() => {
          target.classList.remove('nav-clicked');
        }, 300);
      });
    });
  });
</script>
