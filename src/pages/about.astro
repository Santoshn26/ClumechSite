---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import SystemCard from '@/components/SystemCard.astro';

const seo = {
  title: "About Us | Clumech LLP",
  description: "Founded by industrial engineers, Clumech is on a mission to eliminate operational blind spots in heavy industry and manufacturing."
};
---

<BaseLayout seo={seo}>
  <!-- 1. Hero (Company Story) -->
  <div class="reveal">
    <HeroSection 
      badgeText="OUR STORY"
      title="Built by Engineers, for Engineers"
      subtitle="Clumech was founded by two mechanical engineers who saw what mid-sized manufacturers were missing — a reliable partner who could custom-fabricate components, manage vendor fulfillment, and actually understand the production floor. We built Clumech to be that partner."
      primaryCtaText="Meet the Team"
      primaryCtaLink="#leadership"
      secondaryCtaText="Contact Sales"
      secondaryCtaLink="/contact"
    />
  </div>

  <!-- 2. Mission & Vision -->
  <section class="py-16 md:py-24 bg-light-bg text-light-text">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="reveal-left">
          <h2 class="font-heading text-h2 text-slate-900 mb-4">Our Mission</h2>
          <p class="text-lg text-slate-700 leading-relaxed">
            To be the most reliable custom fabrication and industrial supply partner for mid-sized manufacturers in India — precise, fast, and built to spec every time.
          </p>
        </div>
        <div class="bg-light-card p-8 rounded-2xl border border-light-border shadow-sm reveal-right">
          <h3 class="font-heading text-h3 text-slate-900 mb-4">Our Vision</h3>
          <p class="text-slate-700 leading-relaxed">
            A manufacturing ecosystem where no founder has to compromise on components because good custom fabrication is too slow, too expensive, or too far away.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Leadership Team -->
  <section id="leadership" class="py-16 md:py-24 bg-brand-surface">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16 reveal">
        <p class="font-heading text-label uppercase text-accent-orange mb-4">— LEADERSHIP</p>
        <h2 class="font-heading text-h2 gradient-text">Decades of Combined Experience</h2>
        <p class="text-lg text-brand-text mt-4">Our leadership team brings together mechanical engineering, global IT infrastructure, automotive expertise, and strategic market development.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <!-- Mr. Sameer Sondur -->
        <div class="reveal hover-lift flex flex-col items-center p-6 rounded-2xl bg-brand-card border border-brand-border shadow-sm">
          <div class="relative mb-4">
            <div class="w-14 h-14 bg-accent-orange rounded-full flex items-center justify-center text-white font-mono font-bold text-lg">SS</div>
            <span class="absolute -bottom-2 right-0 text-xs bg-brand-surface text-slate-400 px-2 py-0.5 rounded-full border border-brand-border">Pune</span>
          </div>
          <h3 class="font-heading text-lg font-semibold text-white">Mr. Sameer Sondur</h3>
          <p class="text-accent-orange text-sm font-medium mb-3">Co-Founder</p>
          <p class="text-slate-300 text-sm leading-relaxed max-w-xs">Based out of Pune, Sameer Sondur, Co-founder of Clumech LLP, leverages 13+ years of global IT infrastructure leadership from Huawei. He spearheads Clumech's operations and growth strategy with an entrepreneurial vision focused on scalable manufacturing solutions and unlocking value in emerging industrial markets.</p>
        </div>
        <!-- Mr. Prasannakumar Burli -->
        <div class="reveal delay-100 hover-lift flex flex-col items-center p-6 rounded-2xl bg-brand-card border border-brand-border shadow-sm">
          <div class="relative mb-4">
            <div class="w-14 h-14 bg-accent-orange rounded-full flex items-center justify-center text-white font-mono font-bold text-lg">PB</div>
            <span class="absolute -bottom-2 right-0 text-xs bg-brand-surface text-slate-400 px-2 py-0.5 rounded-full border border-brand-border">Bengaluru</span>
          </div>
          <h3 class="font-heading text-lg font-semibold text-white">Mr. Prasannakumar Burli</h3>
          <p class="text-accent-orange text-sm font-medium mb-3">Co-Founder & Technical Head</p>
          <p class="text-slate-300 text-sm leading-relaxed max-w-xs">Based out of Bangalore As co-founder and technical expert at Clumech LLP, He brings over 23 years of experience from the Automotive & Aerospace Industry. He spearheads the technical division, guiding engineering strategies and product innovation.</p>
        </div>
        <!-- Mr. Subash C.S. -->
        <div class="reveal delay-200 hover-lift flex flex-col items-center p-6 rounded-2xl bg-brand-card border border-brand-border shadow-sm">
          <div class="relative mb-4">
            <div class="w-14 h-14 bg-accent-orange rounded-full flex items-center justify-center text-white font-mono font-bold text-lg">SC</div>
            <span class="absolute -bottom-2 right-0 text-xs bg-brand-surface text-slate-400 px-2 py-0.5 rounded-full border border-brand-border">Bengaluru</span>
          </div>
          <h3 class="font-heading text-lg font-semibold text-white">Mr. Subash C.S.</h3>
          <p class="text-accent-orange text-sm font-medium mb-3">Consultant Director</p>
          <p class="text-slate-300 text-sm leading-relaxed max-w-xs">Mr. Subash C S With 35 years of experience in strategic planning, sales, and market expansion, Mr. Subash C.S. is a dynamic and results-oriented professional. He currently leverages his expertise as Consultant Director for Clumech, focusing on achieving future goals.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Why Clumech (Differentiators) -->
  <section class="py-16 md:py-24 bg-brand-surface"> 
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl mb-16 reveal">
        <p class="font-heading text-label uppercase text-accent-orange mb-4">— THE CLUMECH ADVANTAGE</p>
        <h2 class="font-heading text-h2 gradient-text">Resilient End-to-End Systems</h2>
        <p class="text-lg text-brand-text mt-4">We don't just supply parts. We build the operational reliability your production line depends on — from the component that fits to the vendor who delivers on time.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="reveal hover-lift glow-border">
          <ServiceCard 
            title="Engineer-Founded" 
            description="We read your drawings. We understand tolerances, fits, and what happens when a component is wrong. Technical clarity built in from day one." 
            iconEmoji="⚙️"
          />
        </div>
        <div class="reveal delay-100 hover-lift glow-border">
          <ServiceCard 
            title="Custom-First Manufacturing" 
            description="No forcing standard parts on you. Every component we fabricate starts with your specification — not ours." 
            iconEmoji="📐"
          />
        </div>
        <div class="reveal delay-200 hover-lift glow-border">
          <ServiceCard 
            title="Vendor Coordination Included" 
            description="We don't just supply. We track, follow up, and manage delivery so you're not chasing vendors across WhatsApp." 
            iconEmoji="🤝"
          />
        </div>
        <div class="reveal delay-300 hover-lift glow-border">
          <ServiceCard 
            title="Full Product Range" 
            description="Components, consumables, and fulfillment — from one partner, on one invoice." 
            iconEmoji="📦"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Core Values -->
  <section class="py-16 md:py-24 bg-brand-surface">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <p class="font-heading text-label uppercase text-accent-orange mb-4">— OUR VALUES</p>
        <h2 class="font-heading text-h2 gradient-text">Our Core Engineering Principles</h2>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="reveal hover-lift"><SystemCard title="1. Resilience Over Flash" description="We prioritize system uptime, durability, and fault tolerance over building flashy features that don't directly improve the bottom line of an operation." features={["Reliable Data Sources", "Simple, Robust UIs", "Offline-first Capabilities"]} isDark={true}/></div>
        <div class="reveal delay-100 hover-lift"><SystemCard title="2. Absolute Precision" description="In heavy industry, a variance of millimeters or milliseconds matters. We design our tools to capture absolute truth, minimizing data drift." features={["Accurate Data Entry", "Automated Validation", "Clear Reporting"]} /></div>
        <div class="reveal delay-200 hover-lift"><SystemCard title="3. Operators First" description="If a floor operator can't learn our system in 15 minutes, we've failed. We build intuitive UX that reduces cognitive load during high-stress situations." features={["High-contrast Interfaces", "One-touch Inputs", "Minimal Training Required"]} /></div>
      </div>
    </div>
  </section>
</BaseLayout>