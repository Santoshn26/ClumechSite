---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import SystemCard from '@/components/SystemCard.astro';

const seo = {
  title: "About Us | Clumech LLP",
  description: "Founded by industrial engineers, Clumech is on a mission to eliminate operational blind spots in heavy industry and manufacturing."
};
---

<BaseLayout seo={seo}>
  <!-- 1. Hero (Company Story) -->
  <div class="reveal">
    <HeroSection 
      badgeText="OUR STORY"
      title="Built by Operators, for Operators"
      subtitle="Clumech was founded by engineers who spent decades on the factory floor managing legacy systems. We build the robust operational tools we always wished we had."
      primaryCtaText="Join Our Team"
      primaryCtaLink="/careers"
      secondaryCtaText="Contact Sales"
      secondaryCtaLink="/contact"
    />
  </div>

  <!-- 2. Mission & Vision -->
  <section class="py-16 md:py-24 bg-light-bg text-light-text">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="reveal-left">
          <h2 class="font-heading text-h2 text-slate-900 mb-4">Our Mission</h2>
          <p class="text-lg text-slate-700 leading-relaxed">
            To be the most reliable custom fabrication and industrial supply partner for mid-sized manufacturers in India — precise, fast, and built to spec every time.
          </p>
        </div>
        <div class="bg-light-card p-8 rounded-2xl border border-light-border shadow-sm reveal-right">
          <h3 class="font-heading text-h3 text-slate-900 mb-4">Our Vision</h3>
          <p class="text-slate-700 leading-relaxed">
            A manufacturing ecosystem where no founder has to compromise on components because good custom fabrication is too slow, too expensive, or too far away.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Leadership Team -->
  <section class="py-16 md:py-24 bg-brand-surface">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16 reveal">
        <p class="font-heading text-label uppercase text-accent-orange mb-4">— LEADERSHIP</p>
        <h2 class="font-heading text-h2 gradient-text">Decades of Combined Experience</h2>
        <p class="text-lg text-brand-text mt-4">Our leadership team brings together expertise in mechanical engineering, software architecture, and industrial supply chains.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <!-- Founder 1 -->
        <div class="flex flex-col items-center reveal">
          <div class="w-32 h-32 bg-brand-card border border-brand-border rounded-full mb-6 flex items-center justify-center text-4xl font-heading text-brand-muted shadow-sm"></div>
          <h3 class="font-heading text-xl font-bold text-white">Founder One</h3>
          <p class="text-accent-orange font-semibold text-sm mb-3">CEO & Co-founder</p>
          <p class="text-brand-text text-sm max-w-xs">Former Plant Director with a decade of experience leading industrial automation transformations.</p>
        </div>
        <!-- Founder 2 -->
        <div class="flex flex-col items-center reveal delay-100">
          <div class="w-32 h-32 bg-brand-card border border-brand-border rounded-full mb-6 flex items-center justify-center text-4xl font-heading text-brand-muted shadow-sm"></div>
          <h3 class="font-heading text-xl font-bold text-white">Founder Two</h3>
          <p class="text-accent-orange font-semibold text-sm mb-3">CTO & Co-founder</p>
          <p class="text-brand-text text-sm max-w-xs">Mechanical engineer and pioneer in applying AppSheet for industrial process management.</p>
        </div>
        <!-- Founder 3 -->
        <div class="flex flex-col items-center reveal delay-200">
          <div class="w-32 h-32 bg-brand-card border border-brand-border rounded-full mb-6 flex items-center justify-center text-4xl font-heading text-brand-muted shadow-sm"></div>
          <h3 class="font-heading text-xl font-bold text-white">Founder Three</h3>
          <p class="text-accent-orange font-semibold text-sm mb-3">COO & Co-founder</p>
          <p class="text-brand-text text-sm max-w-xs">Supply chain architect specializing in industrial procurement and logistics for the Indian market.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Why Clumech (Differentiators) -->
  <section class="py-16 md:py-24 bg-brand-surface">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl mb-16 reveal">
        <p class="font-heading text-label uppercase text-accent-orange mb-4">— THE CLUMECH ADVANTAGE</p>
        <h2 class="font-heading text-h2 gradient-text">Resilient End-to-End Systems</h2>
        <p class="text-lg text-brand-text mt-4">We don't just sell products. We provide systems designed to survive and thrive in the harshest industrial environments.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="reveal hover-lift glow-border"><ServiceCard title="Pragmatic Tools" description="Our systems are built on Google Workspace and AppSheet, leveraging the tools your team already knows how to use." iconEmoji="🛠️"/></div>
        <div class="reveal delay-100 hover-lift glow-border"><ServiceCard title="No Lock-in" description="You own the systems we build. There are no proprietary software licenses or long-term contracts. Just a one-time setup fee." iconEmoji="🔑"/></div>
        <div class="reveal delay-200 hover-lift glow-border"><ServiceCard title="Rapid Deployment" description="Forget multi-year IT projects. Our operational dashboards are typically live within two weeks, delivering immediate value." iconEmoji="🚀"/></div>
        <div class="reveal delay-300 hover-lift glow-border"><ServiceCard title="Actionable Intelligence" description="We don't just give you dashboards full of noise. We build tools that provide predictive, actionable alerts directly to the personnel who need them." iconEmoji="📊"/></div>
      </div>
    </div>
  </section>

  <!-- 5. Core Values -->
  <section class="py-16 md:py-24 bg-brand-surface">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <p class="font-heading text-label uppercase text-accent-orange mb-4">— OUR VALUES</p>
        <h2 class="font-heading text-h2 gradient-text">Our Core Engineering Principles</h2>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="reveal hover-lift"><SystemCard title="1. Resilience Over Flash" description="We prioritize system uptime, durability, and fault tolerance over building flashy features that don't directly improve the bottom line of an operation." features={["Reliable Data Sources", "Simple, Robust UIs", "Offline-first Capabilities"]} isDark={true}/></div>
        <div class="reveal delay-100 hover-lift"><SystemCard title="2. Absolute Precision" description="In heavy industry, a variance of millimeters or milliseconds matters. We design our tools to capture absolute truth, minimizing data drift." features={["Accurate Data Entry", "Automated Validation", "Clear Reporting"]} /></div>
        <div class="reveal delay-200 hover-lift"><SystemCard title="3. Operators First" description="If a floor operator can't learn our system in 15 minutes, we've failed. We build intuitive UX that reduces cognitive load during high-stress situations." features={["High-contrast Interfaces", "One-touch Inputs", "Minimal Training Required"]} /></div>
      </div>
    </div>
  </section>
</BaseLayout>