---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import CTABanner from '@/components/CTABanner.astro';

const caseStudies = [
  {
    tag: "[Custom Fabrication]",
    industry: "Auto Components Manufacturer — Pune",
    challenge: "Needed 12 custom chip trolleys for a new CNC line expansion. Standard market options didn't fit the floor dimensions or workflow.",
    approach: "Clumech's team visited the facility, measured the floor layout, and fabricated trolleys to exact spec — with wheel locks, drainage trays, and side rails per client requirement.",
    result: "All 12 trolleys delivered in 9 working days. Zero rework required. Line expansion completed on schedule."
  },
  {
    tag: "[Vendor Consolidation]",
    industry: "Machining Unit — Bengaluru",
    challenge: "Sourcing cutting tools and lubricants from 4 different vendors with inconsistent lead times, different invoices, and variable pricing.",
    approach: "Clumech consolidated supply across all required product categories. Single point of contact, single PO, single invoice per month.",
    result: "Purchase process time reduced by 60%. Pricing dropped 15% vs previous multi-vendor setup. Zero stockouts in 6 months."
  }
];

const seo = {
  title: "Case Studies | Clumech LLP",
  description: "Real outcomes from mid-sized manufacturers who needed custom components, consistent supply, and a partner who follows through."
};
---

<BaseLayout seo={seo}>
  <HeroSection 
    badgeText="PROVEN IN THE FIELD"
    title="How Industry Leaders Win with Clumech"
    subtitle="Real outcomes from mid-sized manufacturers who needed custom components, consistent supply, and a partner who follows through."
    primaryCtaText="Request a Quote"
    primaryCtaLink="/contact"
  />

  <section class="py-16 md:py-24 bg-light-bg text-light-text">
    <div class="max-w-[1200px] mx-auto px-6 space-y-16">
      {caseStudies.map((study, index) => (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 p-8 bg-light-card rounded-2xl border border-light-border shadow-sm reveal hover-lift" style={`transition-delay: ${index * 150}ms`}>
          <div class="md:col-span-1">
            <p class="font-heading text-label uppercase text-accent-orange mb-4">{study.tag}</p>
            <h3 class="font-heading text-h3 text-slate-900">{study.industry}</h3>
          </div>
          <div class="md:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-8">
            <div>
              <h4 class="font-semibold text-slate-900 mb-2">Challenge</h4>
              <p class="text-slate-600 text-sm">{study.challenge}</p>
            </div>
            <div>
              <h4 class="font-semibold text-slate-900 mb-2">Approach</h4>
              <p class="text-slate-600 text-sm">{study.approach}</p>
            </div>
            <div class="sm:col-span-2 mt-4 p-4 bg-light-bg rounded-lg border border-light-border">
              <h4 class="font-semibold text-slate-900 mb-2">Result</h4>
              <p class="text-slate-700 font-medium">{study.result}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-16 md:py-24 bg-brand-surface">
    <div class="max-w-[1200px] mx-auto px-6 reveal">
      <CTABanner 
        headline="Ready for Results Like These?"
        subheadline="Let's perform a free, no-obligation audit of your current operational workflows to identify key areas for improvement."
        buttonText="Book a Free Ops Audit"
        buttonLink="/contact" 
      />
    </div>
  </section>
</BaseLayout>