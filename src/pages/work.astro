---
import BaseLayout from '@/layouts/BaseLayout.astro';

const seo = {
  title: "Our Work | Custom Fabrication Projects | Clumech LLP",
  description: "See custom fabrication and manufacturing projects delivered by Clumech LLP across automotive, aerospace, and industrial sectors in India."
};
---

<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="relative bg-brand-navy text-center overflow-hidden border-b border-brand-border grid-background">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(249,115,22,0.08) 0%, transparent 70%);"></div>
    <div class="max-w-[1200px] mx-auto px-6 w-full py-24 md:py-32 z-10">
      <p class="font-heading text-label uppercase text-accent-orange mb-6 reveal">— OUR WORK</p>
      <h1 class="font-heading text-h1 md:text-display text-shimmer max-w-4xl mx-auto mb-6 reveal delay-100">
        Built by Clumech.<br/>Running in the Field.
      </h1>
      <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto mb-6 leading-relaxed reveal delay-200">
        Custom chip trolleys, precision components, storage cabinets — a selection of what we've designed and delivered.
      </p>
      <p class="text-slate-500 text-sm italic text-center mt-4 max-w-xl mx-auto reveal delay-300">
        Client photography and detailed specs being documented. Project summaries below reflect completed and delivered work.
      </p>
    </div>
  </section>

  <!-- WORK GRID -->
  <section class="bg-light-bg py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-12 reveal">
        <p class="font-heading text-label uppercase text-slate-500 mb-4">— COMPLETED PROJECTS</p>
        <h2 class="font-heading text-h2 text-slate-900">What We've Delivered</h2>
      </div>

      <!-- Filter Buttons -->
      <div id="filter-buttons" class="flex flex-wrap items-center justify-center gap-3 mb-12 reveal">
        <button data-filter="all" class="filter-btn active-filter">All</button>
        <button data-filter="sheet-metal" class="filter-btn">Sheet Metal</button>
        <button data-filter="machining" class="filter-btn">Machining</button>
        <button data-filter="casting" class="filter-btn">Casting</button>
        <button data-filter="supply" class="filter-btn">Supply</button>
      </div>

      <!-- Project Cards Grid -->
      <div id="project-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Project 1 -->
        <div class="project-card bg-white rounded-2xl overflow-hidden border border-slate-200 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 reveal" data-category="sheet-metal">
          <div class="bg-slate-50 p-6 flex items-center justify-center h-48">
            <div class="w-48 h-32 bg-slate-700 rounded-lg border border-slate-600 relative p-2 flex flex-col">
              <div class="h-3 bg-slate-600 rounded-t-lg absolute top-0 left-0 right-0"></div>
              <div class="absolute bottom-1 left-1 flex gap-1"><div class="w-4 h-4 bg-slate-500 rounded-full"></div><div class="w-4 h-4 bg-slate-500 rounded-full"></div></div>
              <div class="absolute bottom-1 right-1 flex gap-1"><div class="w-4 h-4 bg-slate-500 rounded-full"></div><div class="w-4 h-4 bg-slate-500 rounded-full"></div></div>
              <div class="absolute bottom-2 right-8 flex gap-1"><div class="w-1.5 h-1.5 bg-slate-800 rounded-full"></div><div class="w-1.5 h-1.5 bg-slate-800 rounded-full"></div><div class="w-1.5 h-1.5 bg-slate-800 rounded-full"></div></div>
              <p class="text-xs font-mono text-slate-400 mt-auto text-center">Chip Trolley — 900×600×850mm</p>
            </div>
          </div>
          <div class="p-6">
            <span class="text-xs font-mono bg-orange-50 text-orange-600 px-2 py-0.5 rounded-full">Sheet Metal Fabrication</span>
            <h3 class="text-slate-900 font-semibold text-lg mt-3">Custom CNC Chip Trolleys × 12</h3>
            <p class="text-slate-500 text-xs font-mono mt-1">Automotive · Pune</p>
            <div class="border-t border-slate-100 my-4"></div>
            <dl class="space-y-3 text-sm">
              <div><dt class="text-slate-400 text-xs font-mono uppercase">Requirement</dt><dd class="text-slate-600 mt-1">CNC line expansion. Non-standard floor dimensions. 12 units required.</dd></div>
              <div><dt class="text-slate-400 text-xs font-mono uppercase">Delivered</dt><dd class="text-slate-600 mt-1">MS Steel, powder coated, wheel locks, drainage trays, custom dimensions.</dd></div>
              <div><dt class="text-slate-400 text-xs font-mono uppercase">Result</dt><dd class="text-slate-600 mt-1">9 working days. Zero rework.</dd></div>
            </dl>
          </div>
        </div>
        <!-- Project 2 -->
        <div class="project-card bg-white rounded-2xl overflow-hidden border border-slate-200 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 reveal delay-100" data-category="supply">
          <div class="bg-slate-50 p-6 flex items-center justify-center h-48">
            <div class="w-64 h-36 bg-slate-800 rounded-lg border border-slate-700 p-4 flex flex-col">
              <p class="text-xs font-mono text-slate-400">Vendors Before vs After</p>
              <div class="flex-grow flex items-end justify-around gap-4">
                <div class="text-center"><div class="w-6 h-16 bg-red-900/30 rounded-t"></div><p class="text-xs text-slate-500 mt-1">4</p></div>
                <div class="text-center"><div class="w-6 h-20 bg-red-900/30 rounded-t"></div><p class="text-xs text-slate-500 mt-1">Vendors</p></div>
                <p class="text-3xl text-slate-600">→</p>
                <div class="text-center"><div class="w-8 h-24 bg-green-900/30 rounded-t"></div><p class="text-xs text-slate-500 mt-1">1 Partner</p></div>
              </div>
            </div>
          </div>
          <div class="p-6">
            <span class="text-xs font-mono bg-orange-50 text-orange-600 px-2 py-0.5 rounded-full">Supply</span>
            <h3 class="text-slate-900 font-semibold text-lg mt-3">Tooling & Lubrication Consolidation</h3>
            <p class="text-slate-500 text-xs font-mono mt-1">Machining · Bengaluru</p>
            <div class="border-t border-slate-100 my-4"></div>
            <dl class="space-y-3 text-sm">
              <div><dt class="text-slate-400 text-xs font-mono uppercase">Requirement</dt><dd class="text-slate-600 mt-1">4 vendors, inconsistent supply.</dd></div>
              <div><dt class="text-slate-400 text-xs font-mono uppercase">Delivered</dt><dd class="text-slate-600 mt-1">Single PO, all categories covered.</dd></div>
              <div><dt class="text-slate-400 text-xs font-mono uppercase">Result</dt><dd class="text-slate-600 mt-1">60% faster procurement, 15% cost saving.</dd></div>
            </dl>
          </div>
        </div>
        <!-- Project 3 -->
        <div class="project-card bg-white rounded-2xl overflow-hidden border border-slate-200 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 reveal delay-200" data-category="sheet-metal">
          <div class="bg-slate-50 p-6 flex items-center justify-center h-48">
            <div class="w-48 h-40 bg-slate-700 rounded border border-slate-600 p-2 grid grid-cols-3 grid-rows-4 gap-px relative">
              <div class="bg-slate-800"></div><div class="bg-slate-800"></div><div class="bg-slate-800"></div>
              <div class="bg-slate-800"></div><div class="bg-slate-800"></div><div class="bg-slate-800"></div>
              <div class="bg-slate-800"></div><div class="bg-slate-800"></div><div class="bg-slate-800"></div>
              <div class="bg-slate-800"></div><div class="bg-slate-800"></div><div class="bg-slate-800"></div>
              <div class="absolute bottom-2 left-1/2 -translate-x-1/2 w-8 h-2 bg-slate-600 rounded-sm"></div>
              <p class="absolute -bottom-5 left-1/2 -translate-x-1/2 text-xs font-mono text-slate-400 whitespace-nowrap">Grinding Wheel Cabinet — Custom</p>
            </div>
          </div>
          <div class="p-6">
            <span class="text-xs font-mono bg-orange-50 text-orange-600 px-2 py-0.5 rounded-full">Sheet Metal Fabrication</span>
            <h3 class="text-slate-900 font-semibold text-lg mt-3">Grinding Wheel Storage Cabinet</h3>
            <p class="text-slate-500 text-xs font-mono mt-1">Precision Grinding</p>
            <div class="border-t border-slate-100 my-4"></div>
            <dl class="space-y-3 text-sm">
              <div><dt class="text-slate-400 text-xs font-mono uppercase">Requirement</dt><dd class="text-slate-600 mt-1">Safe storage for varying wheel sizes.</dd></div>
              <div><dt class="text-slate-400 text-xs font-mono uppercase">Delivered</dt><dd class="text-slate-600 mt-1">Segmented cabinet, lockable, wall-fit.</dd></div>
              <div><dt class="text-slate-400 text-xs font-mono uppercase">Result</dt><dd class="text-slate-600 mt-1">Capacity doubled. Safety audit passed.</dd></div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMING SOON -->
  <section class="bg-brand-surface py-16 md:py-24">
    <div class="max-w-2xl mx-auto px-6 text-center reveal">
      <h3 class="font-heading text-h3 gradient-text mb-4">More Projects Being Documented</h3>
      <p class="text-slate-400 mb-8">Client permissions and photography are being collected for additional projects. Check back soon or get in touch to discuss your requirement directly.</p>
      <a href="/contact" class="bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300">Start a New Project</a>
    </div>
  </section>
</BaseLayout>

<style>
  .filter-btn {
    @apply px-4 py-2 rounded-full text-sm font-medium transition-all duration-200;
  }
  .active-filter {
    @apply bg-orange-500 text-white;
  }
  .inactive-filter {
    @apply border border-slate-200 text-slate-600 hover:border-orange-500/50;
  }
  .project-card {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .project-card.hidden {
    opacity: 0;
    transform: scale(0.95);
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterContainer = document.getElementById('filter-buttons');
    const projectGrid = document.getElementById('project-grid');
    if (!filterContainer || !projectGrid) return;

    const filterButtons = filterContainer.querySelectorAll('.filter-btn');
    const projectCards = Array.from(projectGrid.querySelectorAll('.project-card'));

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter;

        // Update button styles
        filterButtons.forEach(btn => {
          btn.classList.remove('active-filter');
          btn.classList.add('inactive-filter');
        });
        button.classList.add('active-filter');
        button.classList.remove('inactive-filter');

        // Filter cards
        projectCards.forEach(card => {
          const category = card.dataset.category;
          if (filter === 'all' || filter === category) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });
      });
    });

    // Set initial state for inactive buttons
    filterButtons.forEach(btn => {
      if (!btn.classList.contains('active-filter')) {
        btn.classList.add('inactive-filter');
      }
    });
  });
</script>