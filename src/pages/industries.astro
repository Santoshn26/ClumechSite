---
import BaseLayout from '@/layouts/BaseLayout.astro';

const seo = {
  title: "Industries We Serve | Clumech LLP",
  description: "Clumech delivers custom fabrication and precision components to automotive, aerospace, pharmaceutical, and food-grade manufacturers across India."
};
---

<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="relative bg-brand-navy text-center overflow-hidden border-b border-brand-border grid-background">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(249,115,22,0.08) 0%, transparent 70%);"></div>
    <div class="max-w-[1200px] mx-auto px-6 w-full py-24 md:py-32 z-10">
      <p class="font-heading text-label uppercase text-accent-orange mb-6 reveal">— INDUSTRIES WE SERVE</p>
      <h1 class="font-heading text-h1 md:text-display text-shimmer max-w-4xl mx-auto mb-6 reveal delay-100">
        Precision Manufacturing<br/>Across Every Sector.
      </h1>
      <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto mb-8 leading-relaxed reveal delay-200">
        From automotive production lines to pharmaceutical-grade fabrication — Clumech delivers custom components and storage systems that meet the demands of your industry.
      </p>
      <div class="flex gap-3 flex-wrap justify-center mt-8 reveal delay-300">
        <button data-scroll-to="#automotive" class="border border-white/20 text-slate-300 hover:border-orange-500/50 hover:text-white px-5 py-2 rounded-full text-sm font-medium transition-all duration-200 cursor-pointer">Automotive</button>
        <button data-scroll-to="#aerospace" class="border border-white/20 text-slate-300 hover:border-orange-500/50 hover:text-white px-5 py-2 rounded-full text-sm font-medium transition-all duration-200 cursor-pointer">Aerospace</button>
        <button data-scroll-to="#pharma" class="border border-white/20 text-slate-300 hover:border-orange-500/50 hover:text-white px-5 py-2 rounded-full text-sm font-medium transition-all duration-200 cursor-pointer">Pharma</button>
        <button data-scroll-to="#food-grade" class="border border-white/20 text-slate-300 hover:border-orange-500/50 hover:text-white px-5 py-2 rounded-full text-sm font-medium transition-all duration-200 cursor-pointer">Food Grade</button>
      </div>
    </div>
  </section>

  <!-- INDUSTRY 1: Automotive -->
  <section id="automotive" class="bg-brand-surface py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="reveal-left">
        <p class="font-heading text-label uppercase text-accent-orange mb-4">— AUTOMOTIVE</p>
        <div class="flex items-center gap-4 mb-6">
          <div class="w-10 h-10 bg-orange-500/10 rounded-full flex items-center justify-center text-orange-500"><svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.125-.504 1.125-1.125V14.25m-17.25 4.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H3.375c-.621 0-1.125.504-1.125 1.125v1.5" /></svg></div>
          <h2 class="font-heading text-h2 gradient-text">Built for the Demands of Automotive Production</h2>
        </div>
        <p class="text-lg text-slate-300 leading-relaxed mb-8">Automotive manufacturing floors demand components that perform under continuous load, tight tolerances, and high-volume production cycles. Clumech supplies chip trolleys, precision machined parts, and transmission components to automotive facilities across Pune and Bengaluru.</p>
        <p class="font-semibold text-slate-300 mb-3">What we supply to automotive:</p>
        <ul class="space-y-2 mb-8 text-slate-400">
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Custom Chip Trolleys for CNC sections</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Precision machined components to drawing</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Gear grinding & hobbing components</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Tooling and lubrication for HMC/VMC lines</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Sheet metal storage and handling systems</span></li>
        </ul>
        <div class="flex flex-wrap items-center gap-3 mb-10">
          <span class="bg-white/5 border border-white/10 text-slate-400 text-xs font-mono px-3 py-1 rounded-full">48hr Quote</span>
          <span class="bg-white/5 border border-white/10 text-slate-400 text-xs font-mono px-3 py-1 rounded-full">Custom Dimensions</span>
          <span class="bg-white/5 border border-white/10 text-slate-400 text-xs font-mono px-3 py-1 rounded-full">Zero Rework Policy</span>
        </div>
        <a href="/contact" class="bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300">Request an Automotive Quote</a>
      </div>
      <div class="bg-brand-card border border-white/10 rounded-2xl p-6 reveal-right">
        <p class="font-mono text-orange-500 text-xs tracking-widest uppercase mb-4">AUTOMOTIVE SPEC</p>
        <div class="space-y-3 border-t border-white/5">
          <div class="flex justify-between items-center border-b border-white/5 py-3"><p class="font-mono text-xs text-slate-500 uppercase">TOLERANCE</p><p class="text-white text-sm font-medium">±0.05mm</p></div>
          <div class="flex justify-between items-center border-b border-white/5 py-3"><p class="font-mono text-xs text-slate-500 uppercase">MATERIAL</p><p class="text-white text-sm font-medium">MS Steel / Alloy Steel</p></div>
          <div class="flex justify-between items-center border-b border-white/5 py-3"><p class="font-mono text-xs text-slate-500 uppercase">FINISH</p><p class="text-white text-sm font-medium">Powder Coat / Mill Finish</p></div>
          <div class="flex justify-between items-center border-b border-white/5 py-3"><p class="font-mono text-xs text-slate-500 uppercase">TYPICAL QTY</p><p class="text-white text-sm font-medium">5–50 units per run</p></div>
          <div class="flex justify-between items-center border-b border-white/5 py-3"><p class="font-mono text-xs text-slate-500 uppercase">LEAD TIME</p><p class="text-white text-sm font-medium">7–14 working days</p></div>
        </div>
        <div class="mt-6 pt-4 border-t border-white/10 text-center">
          <span class="bg-green-500/10 text-green-400 border border-green-500/20 font-mono text-xs rounded-full px-3 py-1">ACTIVE SECTOR</span>
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRY 2: Aerospace -->
  <section id="aerospace" class="bg-light-bg py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm reveal-left lg:order-last">
        <p class="font-mono text-orange-500 text-xs tracking-widest uppercase mb-4">AEROSPACE SPEC</p>
        <div class="space-y-3 border-t border-slate-200">
          <div class="flex justify-between items-center border-b border-slate-200 py-3"><p class="font-mono text-xs text-slate-500 uppercase">TOLERANCE</p><p class="text-slate-900 text-sm font-medium">±0.02mm and below</p></div>
          <div class="flex justify-between items-center border-b border-slate-200 py-3"><p class="font-mono text-xs text-slate-500 uppercase">MATERIAL</p><p class="text-slate-900 text-sm font-medium">Alloy Steel / Special Grades</p></div>
          <div class="flex justify-between items-center border-b border-slate-200 py-3"><p class="font-mono text-xs text-slate-500 uppercase">FINISH</p><p class="text-slate-900 text-sm font-medium">Per Client Specification</p></div>
          <div class="flex justify-between items-center border-b border-slate-200 py-3"><p class="font-mono text-xs text-slate-500 uppercase">INSPECTION</p><p class="text-slate-900 text-sm font-medium">100% with Documentation</p></div>
          <div class="flex justify-between items-center border-b border-slate-200 py-3"><p class="font-mono text-xs text-slate-500 uppercase">LEAD TIME</p><p class="text-slate-900 text-sm font-medium">Subject to Complexity</p></div>
        </div>
        <div class="mt-6 pt-4 border-t border-slate-200 text-center">
          <span class="bg-blue-50 text-blue-600 border border-blue-200 font-mono text-xs rounded-full px-3 py-1">PRECISION GRADE</span>
        </div>
      </div>
      <div class="reveal-right">
        <p class="font-heading text-label uppercase text-slate-500 mb-4">— AEROSPACE</p>
        <h2 class="font-heading text-h2 text-slate-900 mb-6">Tolerance-Critical Components for Aerospace Applications</h2>
        <p class="text-lg text-slate-700 leading-relaxed mb-8">Aerospace applications leave no room for variance. Clumech manufactures precision machined components and transmission parts that meet aerospace material specifications and documentation requirements.</p>
        <p class="font-semibold text-slate-800 mb-3">What we supply to aerospace:</p>
        <ul class="space-y-2 mb-8 text-slate-600">
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Precision machined components to CAD drawing</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Gear grinding components (tight tolerance)</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Hobbing components for drive systems</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Custom storage for aerospace tooling</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Documentation and inspection records included</span></li>
        </ul>
        <p class="italic text-slate-500 mb-10">"Every aerospace component ships with full quality inspection documentation."</p>
        <a href="/contact" class="bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300">Discuss Your Aerospace Requirement</a>
      </div>
    </div>
  </section>

  <!-- INDUSTRY 3: Pharmaceutical -->
  <section id="pharma" class="bg-brand-surface py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="reveal-left">
        <p class="font-heading text-label uppercase text-accent-orange mb-4">— PHARMACEUTICAL</p>
        <h2 class="font-heading text-h2 gradient-text mb-6">Compliant Storage & Components for Pharma Environments</h2>
        <p class="text-lg text-slate-300 leading-relaxed mb-8">Pharmaceutical manufacturing requires storage and handling systems that meet hygiene standards, support clean-room adjacent environments, and withstand frequent cleaning cycles. Clumech fabricates compliant storage solutions and cast components for pharma facilities.</p>
        <p class="font-semibold text-slate-300 mb-3">What we supply to pharma:</p>
        <ul class="space-y-2 mb-8 text-slate-400">
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Hygienic sheet metal storage systems</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Custom trolleys with smooth weld finishes</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Grey Cast Iron and Ductile Iron castings</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Precision components for pharma machinery</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Storage solutions for controlled environments</span></li>
        </ul>
        <a href="/contact" class="bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300">Enquire for Pharmaceutical</a>
      </div>
      <div class="bg-brand-card border border-white/10 rounded-2xl p-6 reveal-right">
        <p class="font-mono text-orange-500 text-xs tracking-widest uppercase mb-4">PHARMACEUTICAL SPEC</p>
        <div class="space-y-3 border-t border-white/5">
          <div class="flex justify-between items-center border-b border-white/5 py-3"><p class="font-mono text-xs text-slate-500 uppercase">FINISH</p><p class="text-white text-sm font-medium">Smooth Weld / Hygienic Grade</p></div>
          <div class="flex justify-between items-center border-b border-white/5 py-3"><p class="font-mono text-xs text-slate-500 uppercase">MATERIAL</p><p class="text-white text-sm font-medium">SS / MS per requirement</p></div>
          <div class="flex justify-between items-center border-b border-white/5 py-3"><p class="font-mono text-xs text-slate-500 uppercase">COMPLIANCE</p><p class="text-white text-sm font-medium">Per client GMP requirements</p></div>
          <div class="flex justify-between items-center border-b border-white/5 py-3"><p class="font-mono text-xs text-slate-500 uppercase">CASTING</p><p class="text-white text-sm font-medium">Grey Cast Iron, Ductile Iron</p></div>
          <div class="flex justify-between items-center border-b border-white/5 py-3"><p class="font-mono text-xs text-slate-500 uppercase">LEAD TIME</p><p class="text-white text-sm font-medium">10–18 working days</p></div>
        </div>
        <div class="mt-6 pt-4 border-t border-white/10 text-center">
          <span class="bg-purple-500/10 text-purple-400 border border-purple-500/20 font-mono text-xs rounded-full px-3 py-1">CLEAN ENVIRONMENT READY</span>
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRY 4: Food Grade -->
  <section id="food-grade" class="bg-light-bg py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm reveal-left lg:order-last">
        <p class="font-mono text-orange-500 text-xs tracking-widest uppercase mb-4">FOOD GRADE SPEC</p>
        <div class="space-y-3 border-t border-slate-200">
          <div class="flex justify-between items-center border-b border-slate-200 py-3"><p class="font-mono text-xs text-slate-500 uppercase">MATERIAL</p><p class="text-slate-900 text-sm font-medium">Food-safe MS / SS options</p></div>
          <div class="flex justify-between items-center border-b border-slate-200 py-3"><p class="font-mono text-xs text-slate-500 uppercase">FINISH</p><p class="text-slate-900 text-sm font-medium">Sealed weld, easy-clean</p></div>
          <div class="flex justify-between items-center border-b border-slate-200 py-3"><p class="font-mono text-xs text-slate-500 uppercase">DESIGN</p><p class="text-slate-900 text-sm font-medium">No hidden cavities</p></div>
          <div class="flex justify-between items-center border-b border-slate-200 py-3"><p class="font-mono text-xs text-slate-500 uppercase">TESTING</p><p class="text-slate-900 text-sm font-medium">Per client requirement</p></div>
          <div class="flex justify-between items-center border-b border-slate-200 py-3"><p class="font-mono text-xs text-slate-500 uppercase">LEAD TIME</p><p class="text-slate-900 text-sm font-medium">10–16 working days</p></div>
        </div>
        <div class="mt-6 pt-4 border-t border-slate-200 text-center">
          <span class="bg-green-50 text-green-700 border border-green-200 font-mono text-xs rounded-full px-3 py-1">FOOD SAFE GRADE</span>
        </div>
      </div>
      <div class="reveal-right">
        <p class="font-heading text-label uppercase text-slate-500 mb-4">— FOOD GRADE</p>
        <h2 class="font-heading text-h2 text-slate-900 mb-6">Food-Safe Fabrication for Processing Environments</h2>
        <p class="text-lg text-slate-700 leading-relaxed mb-8">Food manufacturing and processing facilities need storage and handling equipment that is food-safe, easy to clean, and resistant to moisture and chemical cleaning agents. Clumech fabricates custom storage and handling systems for food-grade environments.</p>
        <p class="font-semibold text-slate-800 mb-3">What we supply to food grade:</p>
        <ul class="space-y-2 mb-8 text-slate-600">
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Food-safe material storage systems</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Custom trolleys with sealed welds</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Castings for food processing machinery</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Easy-clean surface finishes</span></li>
          <li class="flex items-start gap-3"><span class="text-accent-orange mt-1">→</span><span>Hygienic design with no hidden cavities</span></li>
        </ul>
        <a href="/contact" class="bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300">Enquire for Food Grade</a>
      </div>
    </div>
  </section>

  <!-- INDUSTRY 5: General Manufacturing -->
  <section class="bg-brand-surface py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-6 text-center reveal">
      <h2 class="font-heading text-h2 gradient-text mb-4">Also Serving General Manufacturing</h2>
      <p class="text-lg text-slate-300 mb-8">Any mid-sized manufacturing or service industry that needs reliable custom fabrication, precision components, or industrial supply — we're the partner you've been looking for.</p>
      <div class="flex flex-wrap items-center justify-center gap-3 mb-10">
        <span class="bg-white/5 border border-white/10 text-slate-400 text-xs font-mono px-3 py-1 rounded-full">Any Industry</span>
        <span class="bg-white/5 border border-white/10 text-slate-400 text-xs font-mono px-3 py-1 rounded-full">Any Batch Size</span>
        <span class="bg-white/5 border border-white/10 text-slate-400 text-xs font-mono px-3 py-1 rounded-full">Quote in 48 Hours</span>
      </div>
      <a href="/contact" class="bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300">Talk to Our Team</a>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-brand-navy py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div 
        class="max-w-3xl mx-auto rounded-3xl p-8 md:p-12 text-center border border-orange-500/20 reveal"
        style="background: linear-gradient(135deg, rgba(249,115,22,0.08) 0%, rgba(30,41,59,0.9) 50%, rgba(249,115,22,0.05) 100%); box-shadow: 0 0 80px rgba(249,115,22,0.08);">
        <h2 class="font-heading text-h2 gradient-text mb-4">Your Industry. Your Specification.</h2>
        <p class="text-slate-300 max-w-lg mx-auto mb-8">Don't see your sector listed? We work across all manufacturing environments. If you have a drawing or requirement, we can quote it.</p>
        <a href="/contact" class="bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300 animate-pulse-glow">Request a Quote</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-scroll-to]').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetSelector = btn.dataset.scrollTo;
        if (!targetSelector) return;
        const target = document.querySelector(targetSelector);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  });
</script>