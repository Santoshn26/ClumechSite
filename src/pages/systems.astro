---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CTABanner from '@/components/CTABanner.astro';

const seo = {
  title: "How We Operate | Clumech LLP",
  description: "Clumech runs its own internal tracking and vendor management systems so every order you place with us is monitored from receipt to delivery."
};

const faqs = [
  { 
    question: "What types of components can Clumech fabricate?",
    answer: "We specialise in customised material storage and handling systems, sheet metal fabricated products, precision machined components, and transmission parts including gear grinding and hobbing. If you have a drawing or specification, we can quote it."
  },
  { 
    question: "How quickly can I get a quote?",
    answer: "For custom fabrication and precision components, we turn around a detailed quote within 48 hours of receiving your drawing or requirement. For standard tooling and lubrication products, we respond the same day."
  },
  { 
    question: "Do you work with small batch or one-off orders?",
    answer: "Yes. We regularly work with mid-sized manufacturers on small batches and one-off custom requirements. There is no minimum order constraint for established clients. Reach out with your requirement and we'll advise accordingly."
  },
  { 
    question: "Which industries do you serve?",
    answer: "We have delivered solutions across automotive, aerospace, pharmaceutical, and food-grade manufacturing sectors. Our focus is any mid-sized manufacturing or service industry that needs reliable custom fabrication or precision component supply."
  },
  {
    question: "Can you fabricate to my existing drawings or CAD files?",
    answer: "Absolutely. Send us your drawing — CAD file, PDF, or even a detailed sketch — and we will review and quote based on your exact specification. Our team has deep experience reading engineering drawings from HMC, VMC, and general machining contexts."
  },
  {
    question: "Do you handle delivery and documentation?",
    answer: "Yes. Every order is dispatched with delivery records and quality inspection certificates. For custom fabricated components, inspection is done before dispatch — not after arrival."
  }
];
---

<BaseLayout seo={seo}>
  <!-- 1. Hero -->
  <div class="reveal">
    <HeroSection 
      badgeText="OPERATIONAL TRANSPARENCY"
      title="You Always Know Where Your Order Stands"
      subtitle="Clumech runs its own internal tracking and vendor management systems — so every order you place with us is monitored from receipt to delivery. No chasing. No guesswork."
      primaryCtaText="Talk to Our Team"
      primaryCtaLink="/contact"
    />
  </div>

  <!-- 2. Operation Blocks -->
  <section class="py-16 md:py-24 bg-light-bg text-light-text">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="reveal hover-lift glow-border">
          <ServiceCard 
            title="Every PO Tracked Internally"
            description="When you raise a purchase order with Clumech, it enters our internal tracking system. You get status updates without having to follow up. We follow up for you."
            iconEmoji="📋"
          />
        </div>
        <div class="reveal delay-100 hover-lift glow-border">
          <ServiceCard 
            title="We Manage Our Suppliers So You Don't Have To"
            description="Our vendor relationships are tracked, scored, and managed. The tools and components you order from us are in stock and dispatched on schedule — because we hold our suppliers to the same standard you hold us."
            iconEmoji="🔗"
          />
        </div>
        <div class="reveal delay-200 hover-lift glow-border">
          <ServiceCard 
            title="Quality Inspection on Every Fabricated Part"
            description="Every custom component leaves our facility with an inspection record. You know what you're getting before it arrives on your floor."
            iconEmoji="🏅"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Tech Transparency Note -->
  <section class="py-16 md:py-24 bg-brand-surface">
    <div class="max-w-3xl mx-auto px-6 text-center reveal">
      <p class="font-heading text-label uppercase text-accent-orange mb-4">— HOW WE OPERATE</p>
      <h2 class="font-heading text-h2 gradient-text">Powered by Pragmatic Tools</h2>
      <p class="text-lg text-slate-300 mt-4">
        Our internal operations run on AppSheet and Google Workspace — purpose-built tools that give our team real-time visibility into every order, vendor, and delivery.
      </p>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 md:py-24 bg-light-bg text-light-text">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <p class="font-heading text-label uppercase text-accent-orange mb-4">— FAQ</p>
        <h2 class="font-heading text-h2 text-slate-900">Frequently Asked Questions</h2>
      </div>
      <div class="space-y-4 reveal" id="faq-accordion">
        {faqs.map((faq) => (
          <div class="faq-item bg-light-card border border-light-border rounded-lg overflow-hidden">
            <button class="faq-question w-full flex justify-between items-center text-left p-6 font-semibold text-slate-900 hover:bg-slate-50 transition-colors">
              <span>{faq.question}</span>
              <svg class="faq-icon w-5 h-5 text-slate-500 transform transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-answer hidden">
              <div class="p-6 pt-0 text-slate-700 leading-relaxed">{faq.answer}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-16 md:py-24 bg-brand-surface">
    <div class="max-w-[1200px] mx-auto px-6 reveal">
      <CTABanner 
        headline="Want This Level of Reliability for Your Supply?" 
        subheadline="Partner with a team that values operational clarity as much as you do. Let's discuss your next requirement." 
        buttonText="Request a Quote" 
        buttonLink="/contact"
      />
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const accordion = document.getElementById('faq-accordion');
    if (!accordion) return;
    const faqItems = accordion.querySelectorAll('.faq-item');
    if (!faqItems.length) return;
    faqItems.forEach(item => {
      const question = item.querySelector('.faq-question');
      const answer = item.querySelector('.faq-answer');
      const icon = item.querySelector('.faq-icon');
      if (!question || !answer || !icon) return;
      question.addEventListener('click', () => {
        const isOpen = !answer.classList.contains('hidden');
        faqItems.forEach(otherItem => {
          otherItem.querySelector('.faq-answer')?.classList.add('hidden');
          otherItem.querySelector('.faq-icon')?.classList.remove('rotate-180');
        });
        if (!isOpen) {
          answer.classList.remove('hidden');
          icon.classList.add('rotate-180');
        }
      });
    });
  });
</script>
      </div>
    </div>
  </section>

  <!-- 5. FAQ -->
  <section class="py-16 md:py-24 bg-light-bg text-light-text">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <p class="font-heading text-label uppercase text-accent-orange mb-4">— FAQ</p>
        <h2 class="font-heading text-h2 text-slate-900">Frequently Asked Questions</h2>
      </div>
      <div class="space-y-4 reveal" id="faq-accordion">
        {faqs.map((faq) => (
          <div class="faq-item bg-light-card border border-light-border rounded-lg overflow-hidden">
            <button class="faq-question w-full flex justify-between items-center text-left p-6 font-semibold text-slate-900 hover:bg-slate-50 transition-colors">
              <span>{faq.question}</span>
              <svg class="faq-icon w-5 h-5 text-slate-500 transform transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-answer hidden">
              <div class="p-6 pt-0 text-slate-700 leading-relaxed">{faq.answer}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. CTA -->
  <section class="py-16 md:py-24 bg-brand-surface">
    <div class="max-w-[1200px] mx-auto px-6 reveal">
      <CTABanner headline="See Your Unified Dashboard" subheadline="Schedule a personalized demo to see how our AppSheet tools can consolidate your operational data into a single source of truth." buttonText="Book a Free Demo" buttonLink="/demo"/>
    </div>
  </section>
</BaseLayout>

