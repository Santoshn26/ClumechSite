---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABanner from '@/components/CTABanner.astro';

const seo = {
  title: "Industrial Products & Custom Fabrication | Clumech LLP",
  description: "Clumech supplies cutting tools, lubricants, material handling products and manufactures custom components for mid-sized industrial businesses across India."
};
---

<BaseLayout seo={seo}>
  <!-- SECTION 1: Hero -->
  <section class="relative bg-brand-navy text-center overflow-hidden border-b border-brand-border grid-background">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(249,115,22,0.08) 0%, transparent 70%);"></div>
    <div class="max-w-[1200px] mx-auto px-6 w-full py-24 md:py-32 z-10">
      <p class="font-heading text-label uppercase text-accent-orange mb-6 reveal">— PRODUCT CATALOGUE</p>
      <h1 class="font-heading text-h1 md:text-display text-shimmer max-w-4xl mx-auto mb-6 reveal delay-100">
        Everything Your Facility Needs.<br /> Custom Built or Ready to Ship.
      </h1>
      <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto mb-10 leading-relaxed reveal delay-200">
        From precision-fabricated components to industrial consumables — Clumech supplies mid-sized manufacturers across India with what they need, when they need it.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center reveal delay-300">
        <a href="#custom-fabrication" class="px-6 py-2.5 rounded-full font-semibold text-sm text-orange-400 border border-orange-500/40 bg-brand-navy/50 hover:bg-orange-500/10 hover:text-orange-300 transition-all duration-200">Custom Fabrication</a>
        <a href="#ready-stock" class="px-6 py-2.5 rounded-full font-semibold text-sm text-orange-400 border border-orange-500/40 bg-brand-navy/50 hover:bg-orange-500/10 hover:text-orange-300 transition-all duration-200">Ready Stock Products</a>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Custom Fabrication -->
  <section id="custom-fabrication" class="bg-brand-surface py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
      <div class="reveal">
        <p class="font-heading text-label uppercase text-accent-orange mb-4">— CUSTOM FABRICATION</p>
        <h2 class="font-heading text-h2 gradient-text mb-6">Built to Your Drawing. Delivered to Your Floor.</h2>
        <p class="text-lg text-slate-300 leading-relaxed mb-8">
          We manufacture custom industrial components from client-provided drawings and specifications. No minimum order constraints for established clients. Quality inspection included on every fabricated piece.
        </p>
        <ul class="space-y-3 mb-10">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-orange mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-300">Chip trolleys and material handling units</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-orange mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-300">Custom storage racks and space utilisation systems</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-orange mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-300">Precision jigs, fixtures, and assemblies</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-orange mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-slate-300">Any component to your CAD drawing or sketch</span>
          </li>
        </ul>
        <a href="/contact" class="bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300">Request a Fabrication Quote</a>
      </div>
      <div class="reveal delay-100" style="box-shadow: 0 0 60px rgba(249,115,22,0.08)">
        <div class="bg-[#0F172A] border border-white/10 rounded-2xl p-6">
          <div class="flex items-center gap-2 mb-6">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
            </div>
            <p class="font-mono text-xs text-slate-500">fabrication-req-042.pdf</p>
          </div>
          <div class="space-y-4">
            <div class="flex justify-between items-center border-b border-white/5 pb-4">
              <p class="font-mono text-xs text-slate-500 uppercase tracking-wider">Component Type</p>
              <p class="text-white text-sm font-medium">Custom Chip Trolley</p>
            </div>
            <div class="flex justify-between items-center border-b border-white/5 pb-4">
              <p class="font-mono text-xs text-slate-500 uppercase tracking-wider">Material</p>
              <p class="text-white text-sm font-medium">MS Steel 3mm</p>
            </div>
            <div class="flex justify-between items-center border-b border-white/5 pb-4">
              <p class="font-mono text-xs text-slate-500 uppercase tracking-wider">Quantity</p>
              <p class="text-white text-sm font-medium">12 units</p>
            </div>
            <div class="flex justify-between items-center pb-2">
              <p class="font-mono text-xs text-slate-500 uppercase tracking-wider">Delivery</p>
              <p class="text-white text-sm font-medium">9 working days</p>
            </div>
          </div>
          <div class="mt-6 pt-6 border-t border-white/10">
            <div class="flex justify-between items-center mb-3">
              <span class="bg-green-500/10 text-green-400 border border-green-500/20 text-xs font-mono px-3 py-1 rounded-full">IN PRODUCTION</span>
              <span class="text-orange-500 text-xs font-mono">65%</span>
            </div>
            <div class="w-full bg-brand-card rounded-full h-1.5">
              <div class="bg-orange-500 h-1.5 rounded-full" style="width: 65%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Product Categories Grid -->
  <section id="ready-stock" class="bg-light-bg py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16 reveal">
        <p class="font-heading text-label uppercase text-slate-500 mb-4">— INDUSTRIAL SUPPLY</p>
        <h2 class="font-heading text-h2 text-slate-900">Five Product Categories. One Reliable Partner.</h2>
        <p class="text-lg text-slate-600 mt-4">
          Stop managing 5 vendors. Clumech stocks and supplies everything your facility needs on a single purchase order.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Card 1: Cutting Tools -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 reveal">
          <div class="w-16 h-16 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 text-3xl">⚙️</div>
          <h3 class="font-heading font-semibold text-lg text-slate-900 mt-4">Cutting Tools & Inserts</h3>
          <p class="text-slate-600 text-sm leading-relaxed mt-2">Precision cutting tools and inserts for CNC, turning, milling, and machining operations. Sourced from reliable manufacturers.</p>
          <ul class="text-slate-500 text-xs mt-3 space-y-1">
            <li>• Turning inserts</li>
            <li>• Milling cutters</li>
            <li>• Drills & reamers</li>
          </ul>
          <a href="/contact" class="font-semibold text-sm text-accent-orange hover:underline mt-4 inline-block">Enquire Now →</a>
        </div>
        <!-- Card 2: Lubricants -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 reveal delay-100">
          <div class="w-16 h-16 rounded-2xl bg-amber-50 flex items-center justify-center text-amber-600 text-3xl">💧</div>
          <h3 class="font-heading font-semibold text-lg text-slate-900 mt-4">Lubricants</h3>
          <p class="text-slate-600 text-sm leading-relaxed mt-2">Industrial lubricants for machinery, hydraulics, and metal working. Suitable for high-load and high-temperature applications.</p>
          <ul class="text-slate-500 text-xs mt-3 space-y-1">
            <li>• Cutting fluids</li>
            <li>• Hydraulic oils</li>
            <li>• Specialty greases</li>
          </ul>
          <a href="/contact" class="font-semibold text-sm text-accent-orange hover:underline mt-4 inline-block">Enquire Now →</a>
        </div>
        <!-- Card 3: Surface Cleaning -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 reveal delay-200">
          <div class="w-16 h-16 rounded-2xl bg-green-50 flex items-center justify-center text-green-600 text-3xl">✨</div>
          <h3 class="font-heading font-semibold text-lg text-slate-900 mt-4">Surface Cleaning</h3>
          <p class="text-slate-600 text-sm leading-relaxed mt-2">Industrial surface cleaning products for machinery, shop floors, and metal components. Safe, effective, and industrial-grade.</p>
          <ul class="text-slate-500 text-xs mt-3 space-y-1">
            <li>• Degreasers</li>
            <li>• Metal cleaners</li>
            <li>• Anti-rust treatments</li>
          </ul>
          <a href="/contact" class="font-semibold text-sm text-accent-orange hover:underline mt-4 inline-block">Enquire Now →</a>
        </div>
        <!-- Card 4: Material Handling -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 reveal">
          <div class="w-16 h-16 rounded-2xl bg-purple-50 flex items-center justify-center text-purple-600 text-3xl">📦</div>
          <h3 class="font-heading font-semibold text-lg text-slate-900 mt-4">Material Handling & Storage</h3>
          <p class="text-slate-600 text-sm leading-relaxed mt-2">Material handling equipment and storage solutions including standard and custom configurations for your facility.</p>
          <ul class="text-slate-500 text-xs mt-3 space-y-1">
            <li>• Storage racks</li>
            <li>• Trolleys</li>
            <li>• Bin systems</li>
          </ul>
          <a href="/contact" class="font-semibold text-sm text-accent-orange hover:underline mt-4 inline-block">Enquire Now →</a>
        </div>
        <!-- Card 5: Housekeeping -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 reveal delay-100">
          <div class="w-16 h-16 rounded-2xl bg-red-50 flex items-center justify-center text-red-500 text-3xl">🛡️</div>
          <h3 class="font-heading font-semibold text-lg text-slate-900 mt-4">Housekeeping & Hygiene</h3>
          <p class="text-slate-600 text-sm leading-relaxed mt-2">Industrial housekeeping and hygiene products for manufacturing facilities. Keeps your shop floor clean and compliant.</p>
          <ul class="text-slate-500 text-xs mt-3 space-y-1">
            <li>• Floor cleaners</li>
            <li>• Safety absorbents</li>
            <li>• Facility hygiene kits</li>
          </ul>
          <a href="/contact" class="font-semibold text-sm text-accent-orange hover:underline mt-4 inline-block">Enquire Now →</a>
        </div>
        <!-- Card 6: Cotton -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 reveal delay-200">
          <div class="w-16 h-16 rounded-2xl bg-sky-50 flex items-center justify-center text-sky-600 text-3xl">🌿</div>
          <h3 class="font-heading font-semibold text-lg text-slate-900 mt-4">Premium Indian Cotton</h3>
          <p class="text-slate-600 text-sm leading-relaxed mt-2">100% pure bleached and non-bleached Indian cotton for industrial and OEM use. Export quality. Competitive pricing.</p>
          <ul class="text-slate-500 text-xs mt-3 space-y-1">
            <li>• Absorbent cotton wool</li>
            <li>• Bleached comber for OEM</li>
            <li>• Grey cotton</li>
          </ul>
          <a href="/contact" class="font-semibold text-sm text-accent-orange hover:underline mt-4 inline-block">Enquire Now →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: Why Source from Clumech -->
  <section class="bg-brand-surface py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16 reveal">
        <h2 class="font-heading text-h2 gradient-text">Why Manufacturers Choose Clumech</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Column 1 -->
        <div class="bg-brand-card p-8 rounded-2xl border border-brand-border glow-border reveal">
          <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center text-orange-500 mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
          </div>
          <h3 class="text-white font-semibold text-lg mb-2">One Partner, One Invoice</h3>
          <p class="text-slate-300 text-sm leading-relaxed">Stop managing 5 vendor relationships. Everything on a single PO, single invoice, delivered together.</p>
        </div>
        <!-- Column 2 -->
        <div class="bg-brand-card p-8 rounded-2xl border border-brand-border glow-border reveal delay-100">
          <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center text-orange-500 mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-white font-semibold text-lg mb-2">48-Hour Quote Turnaround</h3>
          <p class="text-slate-300 text-sm leading-relaxed">Custom fabrication quote in 48 hours. Ready-stock enquiries answered same day. No chasing, no waiting.</p>
        </div>
        <!-- Column 3 -->
        <div class="bg-brand-card p-8 rounded-2xl border border-brand-border glow-border reveal delay-200">
          <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center text-orange-500 mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-white font-semibold text-lg mb-2">Quality Inspection Included</h3>
          <p class="text-slate-300 text-sm leading-relaxed">Every fabricated component ships with an inspection record. No surprises when it lands on your floor.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 5: How to Order -->
  <section class="bg-light-bg py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16 reveal">
        <p class="font-heading text-label uppercase text-slate-500 mb-4">— THE PROCESS</p>
        <h2 class="font-heading text-h2 text-slate-900">Getting Started is Simple</h2>
      </div>
      <div class="relative">
        <!-- Desktop connector line -->
        <div class="hidden md:block absolute top-10 left-0 w-full h-px bg-slate-300 border-t border-dashed border-slate-300"></div>
        
        <div class="relative grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8">
          <!-- Step 1 -->
          <div class="text-center md:text-left reveal">
            <p class="absolute -top-8 left-1/2 -translate-x-1/2 md:left-0 md:-translate-x-0 font-mono text-6xl font-bold text-orange-500/10 -z-10">01</p>
            <h3 class="font-semibold text-slate-900 mb-2">Share Your Requirement</h3>
            <p class="text-slate-600 text-sm">Tell us what you need — a drawing, a description, or just a product category. We'll take it from there.</p>
          </div>
          <!-- Step 2 -->
          <div class="text-center md:text-left reveal delay-100">
            <p class="absolute -top-8 left-1/2 -translate-x-1/2 md:left-0 md:-translate-x-0 font-mono text-6xl font-bold text-orange-500/10 -z-10">02</p>
            <h3 class="font-semibold text-slate-900 mb-2">Receive Your Quote</h3>
            <p class="text-slate-600 text-sm">We send a detailed quote within 48 hours for custom fab, same day for stock products.</p>
          </div>
          <!-- Step 3 -->
          <div class="text-center md:text-left reveal delay-200">
            <p class="absolute -top-8 left-1/2 -translate-x-1/2 md:left-0 md:-translate-x-0 font-mono text-6xl font-bold text-orange-500/10 -z-10">03</p>
            <h3 class="font-semibold text-slate-900 mb-2">Approve and We Begin</h3>
            <p class="text-slate-600 text-sm">Once you approve, fabrication starts or stock is reserved for dispatch.</p>
          </div>
          <!-- Step 4 -->
          <div class="text-center md:text-left reveal delay-300">
            <p class="absolute -top-8 left-1/2 -translate-x-1/2 md:left-0 md:-translate-x-0 font-mono text-6xl font-bold text-orange-500/10 -z-10">04</p>
            <h3 class="font-semibold text-slate-900 mb-2">Delivery with Documentation</h3>
            <p class="text-slate-600 text-sm">Your order arrives with delivery records and quality inspection certificates.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 6: Final CTA -->
  <section class="bg-brand-surface py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div 
        class="max-w-3xl mx-auto rounded-3xl p-8 md:p-12 text-center border border-orange-500/20 reveal"
        style="
          background: linear-gradient(135deg, rgba(249,115,22,0.08) 0%, rgba(30,41,59,0.9) 50%, rgba(249,115,22,0.05) 100%);
          box-shadow: 0 0 80px rgba(249,115,22,0.08);
        "
      >
        <p class="font-heading text-label uppercase text-accent-orange mb-4">READY TO ORDER?</p>
        <h2 class="font-heading text-h2 gradient-text mb-4">Send Us Your Requirement Today</h2>
        <p class="text-slate-300 max-w-lg mx-auto mb-8">
          Custom component or stock product — describe what you need and we'll get back with a quote within 48 hours.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center">
          <a href="/contact" class="bg-accent-orange hover:bg-accent-orangeHover text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-cta-orange hover:shadow-glow-orange-lg transition-all duration-300 animate-pulse-glow">Request a Quote</a>
          <a href="tel:+919845349735" class="border border-brand-border hover:border-accent-orange/50 text-slate-300 hover:text-white bg-transparent hover:bg-brand-card/50 px-6 py-3 rounded-xl font-semibold text-sm transition-all duration-200">Call Us Now</a>
        </div>
        <p class="text-slate-500 text-sm mt-8">Or email us at <a href="mailto:info@clumech.com" class="text-slate-400 hover:text-white hover:underline">info@clumech.com</a></p>
      </div>
    </div>
  </section>
</BaseLayout>